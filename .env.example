# Copy this file to `.env` and fill in your key. NEVER commit `.env` (it is gitignored).
#
# Provider is config, not code (OpenAI-compatible seam). The development default
# is Zhipu GLM-4.5-Flash on z.ai — always free, no credit card.
#   1. Sign up at https://z.ai  (the INTERNATIONAL site — NOT bigmodel.cn,
#      which requires a Chinese phone number).
#   2. Profile menu -> API Keys -> create a key. Paste it into LLM_API_KEY below.

# ----------------------------------------------------------------------------
# ACTIVE PROFILE (what the app + eval use right now) — dev default: z.ai GLM
# ----------------------------------------------------------------------------
# NOTE: base URL is the /api/paas/v4 path (OpenAI-shaped), verified working
# 2026-07-11. The /api/openai/v1 path returns a wrapped 404 — do not use it.
LLM_API_KEY=
LLM_BASE_URL=https://api.z.ai/api/paas/v4
LLM_MODEL=glm-4.5-flash

# GLM-4.5-Flash is a *thinking* model whose reasoning is UNBOUNDED — it can burn
# the entire token budget on hidden reasoning and return empty content (raising
# max_tokens does NOT reliably fix it; more budget just means more rambling).
# For this deterministic scoring task we turn thinking OFF: fast, cheap, reliable.
# LLM_EXTRA_BODY is provider-specific JSON merged into the request; leave it blank
# for providers that have no thinking toggle.
LLM_EXTRA_BODY={"thinking": {"type": "disabled"}}

# ============================================================================
# BAKE-OFF PROVIDER PROFILES (Phase 6 Task 4) — fill the keys you want to test
# ============================================================================
# The connection details (base_url / model / extra_body) for each provider now
# live in a registry: evals/providers.py. You do NOT hand-swap the ACTIVE block
# above anymore. Just paste each provider's key into its *_API_KEY var below and:
#
#   .venv/bin/python evals/evaluate.py --openrouter      # RECOMMENDED: bake off
#                                                        # the OpenRouter set + glm
#   .venv/bin/python evals/evaluate.py --all-providers   # direct providers (below)
#   .venv/bin/python evals/evaluate.py --provider gemini  # run just one direct
#
# ** --openrouter is the preferred path (2026-07-19). ** One funded OpenRouter
# key (OPEN_ROUTER_API_KEY, at the bottom) proxies many models through a single
# base_url, so it sidesteps every free-tier wall the DIRECT providers hit (Gemini
# 15 RPM + new-account gating; Groq 100k tokens/DAY; DeepSeek needs a balance).
# It prints a projected-cost heads-up before spending. The curated model set +
# est. costs live in evals/providers.py (OPENROUTER_MODELS). Bake-off finding
# (52-row golden): gpt-4o-mini led (Processed 11/12), glm-4.5-flash a close free
# 2nd — Amber kept glm as default; re-run at check-ins. Any run activates profiles
# in-process (it never touches this file), preflights one row so a bad key /
# unfunded balance is reported (not 52 errors), guards coverage (a rate-capped
# partial run is excluded from the recommendation), and recommends an
# eval-selected default. A provider/model with no key here is skipped.
#
# Model ids DRIFT and free tiers change — the registry's ids were verified
# 2026-07-19. Thinking stays DISABLED on reasoning models (2026-07-11 pitfall):
# the registry sets each provider's extra_body (GLM/Qwen off; the rest blank).
# The *_API_KEY names below are read by the registry to locate each key.

# --- Google Gemini ----------------------------------------------------------
# Key: https://aistudio.google.com/apikey   (Google AI Studio, has a free tier)
GEMINI_API_KEY=
#   registry model: gemini-3.1-flash-lite   (flash-LITE = thinking off by default)
#   NOTE: gemini-2.0-flash was shut down 2026-06-01, and 2.0/2.5-flash-lite are
#   gated for NEW accounts (2.5-flash-lite 404s "no longer available to new
#   users" on the actual call even though it lists). 3.1-flash-lite is current.
#   Free tier: ~1500 req/day, 30 RPM, no card.

# --- Groq (very fast; hosts Llama / Qwen / others) --------------------------
# Key: https://console.groq.com/keys
GROQ_API_KEY=
#   registry model: llama-3.3-70b-versatile   (non-thinking -> extra_body blank)
#   (Groq also serves deepseek-r1-distill / qwen reasoning models — those THINK;
#    avoid them here or they'll ramble like GLM. Free tier, no card.)

# --- DeepSeek ---------------------------------------------------------------
# Key: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=
#   registry model: deepseek-chat   (V4 Flash, non-thinking -> extra_body blank)
#   (Do NOT use deepseek-reasoner — it thinks and will eat the token budget.)
#   ⚠ NO perpetual free tier: only a one-time 5M-token signup grant (30 days),
#   then it needs a funded balance — an empty account returns 402 "Insufficient
#   Balance" and the bake-off skips it.

# --- Qwen (Alibaba Model Studio / DashScope, international endpoint) ---------
# Key: https://modelstudio.console.alibabacloud.com   (DashScope API key)
QWEN_API_KEY=
#   registry model: qwen-plus   (extra_body={"enable_thinking": false} — it THINKS
#   by default; qwen-turbo is cheaper if you edit the registry). Free: 1M in /
#   1M out for 90 days on a new intl (Singapore) Model Studio account.

# --- OpenRouter (RECOMMENDED bake-off path) ---------------------------------
# Key: https://openrouter.ai/keys   (fund the account — pay-as-you-go, ~$5 min)
# One key proxies ALL models (deepseek / gemini / llama / qwen / gpt-4o-mini /
# mistral / gpt-oss / …) via https://openrouter.ai/api/v1 — the model NAME is the
# only variable. Run: `.venv/bin/python evals/evaluate.py --openrouter`. The model
# set + est. per-run cost live in evals/providers.py (OPENROUTER_MODELS); a full
# 8-model pass over the 52-row golden set is ~$0.36. Reasoning is disabled per
# model there (gpt-oss MANDATES it → set to effort:low). Model slugs drift —
# `curl https://openrouter.ai/api/v1/models` lists current ids + live pricing.
OPEN_ROUTER_API_KEY=